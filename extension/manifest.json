{
  "manifest_version": 3,
  "name": "Astro D1 Parser",
  "description": "Toolbar popup parser for Astro.Expert D1/D9 cards.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Astro D1",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    },
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab", "tabs", "clipboardWrite"],
  "host_permissions": [
    "https://*.astro.expert/*",
    "http://*.astro.expert/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.astro.expert/*",
        "http://*.astro.expert/*"
      ],
      "js": ["vimshottari.js", "parser-core.js", "content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
